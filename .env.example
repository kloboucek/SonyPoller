# Required
TV_ADB_HOST=TV_IP_ADDRESS:5555
HA_URL=http://HOME_ASSISTANT_HOST:8123
HA_TOKEN=replace_with_long_lived_home_assistant_token

# Home Assistant entity to create/update
HA_ENTITY_ID=sensor.sony_tv_playback_state

# Polling and reliability
POLL_INTERVAL=1
ADB_TIMEOUT=2
UPDATE_ON_CHANGE_ONLY=true
UNKNOWN_AFTER_FAILURES=3

# Container health endpoint
HEALTH_PORT=8080
LOG_LEVEL=INFO
